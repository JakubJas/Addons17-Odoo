<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_overtime_report_wizard" model="ir.ui.view">
            <field name="name">overtime.report.wizard.form</field>
            <field name="model">overtime.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte Gestoría">
                    <group>
                        <field name="report_type" invisible="1"/>
                        <field name="employee_id" invisible="report_type != 'employee'"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <footer>
                        <button name="action_export_payroll_excel"
                                type="object"
                                string="Exportar Gestoría"
                                invisible="report_type != 'payroll'"
                                class="btn-primary"/>

                        <button name="action_export_employee_excel"
                                type="object"
                                string="Exportar Trabajador"
                                invisible="report_type != 'employee'"
                                class="btn-primary"/>

                        <button name="action_export_attendance_excel"
                                type="object"
                                string="Exportar Asistencia"
                                invisible="report_type != 'attendance'"
                                class="btn-primary"/>
                        <button string="Cancelar" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_overtime_report_payroll" model="ir.actions.act_window">
            <field name="name">Reporte Gestoría</field>
            <field name="res_model">overtime.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'report_type': 'payroll'}</field>
        </record>

        <record id="action_overtime_report_employee" model="ir.actions.act_window">
            <field name="name">Reporte Trabajador</field>
            <field name="res_model">overtime.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'report_type': 'employee'}</field>
        </record>

        <record id="action_overtime_report_attendance" model="ir.actions.act_window">
            <field name="name">Reporte Asistencia</field>
            <field name="res_model">overtime.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'report_type': 'attendance'}</field>
        </record>

    </data>
</odoo>