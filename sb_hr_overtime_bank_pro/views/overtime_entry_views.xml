<odoo>

    <record id="view_hr_overtime_entry_tree" model="ir.ui.view">
        <field name="name">hr.overtime.entry.tree</field>
        <field name="model">hr.overtime.entry</field>
        <field name="arch" type="xml">
            <tree string="Overtime Entries">
                <field name="employee_id" string="Empleado"/>
                <field name="date" string="Fecha"/>
                <field name="type" string="Tipo"/>
                <field name="signed_hours" string="Horas" widget="float_time" sum="Total"/>
                <field name="state" string="Estado"/>
                <field name="description" string="Descripción"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_overtime_entry_form" model="ir.ui.view">
        <field name="name">hr.overtime.entry.form</field>
        <field name="model">hr.overtime.entry</field>
        <field name="arch" type="xml">
            <form string="Overtime Entry">
                <header>
                    <button name="action_confirm"
                            string="Confirmar"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_set_to_draft"
                            string="Volver a Borrador"
                            type="object"
                            invisible="state != 'done' or attendance_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id" readonly="state == 'done'" string="Empleado"/>
                        <field name="date" readonly="state == 'done'" string="Fecha"/>
                        <field name="hours" readonly="state == 'done'" string="Horas" widget="float_time"/>
                        <field name="type" readonly="state == 'done'" string="Tipo"/>
                        <field name="attendance_id" invisible="1"/>
                        <field name="leave_allocation_id" invisible="1"/>
                    </group>

                    <group>
                        <field name="reference" readonly="state == 'done'" string="Referencia"/>
                        <field name="description" readonly="state == 'done'" string="Descripción"/>
                    </group>

                    <group string="Adjunto">
                        <field name="attachment" filename="attachment_filename" readonly="state == 'done'"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_hr_overtime_entry_search" model="ir.ui.view">
        <field name="name">hr.overtime.entry.search</field>
        <field name="model">hr.overtime.entry</field>
        <field name="arch" type="xml">
            <search string="Search Overtime">
                <field name="employee_id" string="Empleado"/>
                <field name="date" string="Fecha"/>

                <filter name="approved"
                        string="Aprobado"
                        domain="[('state','=','done')]"/>

                <filter name="pending"
                        string="Pendiente"
                        domain="[('state','=','draft')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_employee"
                            string="Empleado"
                            context="{'group_by':'employee_id'}"/>

                    <filter name="group_date"
                            string="Fecha"
                            context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_overtime_entries" model="ir.actions.act_window">
        <field name="name">Overtime Entries</field>
        <field name="res_model">hr.overtime.entry</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_overtime_entry_search"/>
        <field name="context">{'group_by': 'employee_id'}</field>
    </record>

     <record id="action_create_overtime_entry" model="ir.actions.act_window">
        <field name="name">Nuevo registro de horas extra</field>
        <field name="res_model">hr.overtime.entry</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
