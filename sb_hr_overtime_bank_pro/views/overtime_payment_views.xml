<odoo>

    <record id="view_hr_overtime_payment_tree" model="ir.ui.view">
        <field name="name">hr.overtime.payment.tree</field>
        <field name="model">hr.overtime.payment</field>
        <field name="arch" type="xml">
            <tree string="Overtime Payments">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="hours"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_overtime_payment_form" model="ir.ui.view">
        <field name="name">hr.overtime.payment.form</field>
        <field name="model">hr.overtime.payment</field>
        <field name="arch" type="xml">
            <form string="Overtime Payment">
                <header>
                    <button name="action_confirm"
                            string="Confirmar"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_set_to_draft"
                            string="Volver a Borrador"
                            type="object"
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id" readonly="state == 'done'"/>
                        <field name="date" readonly="state == 'done'"/>
                        <field name="hours" readonly="state == 'done'"/>
                        <field name="overtime_entry_id" invisible="1"/>
                    </group>

                    <group>
                        <field name="description" readonly="state == 'done'"/>
                    </group>

                    <group string="Attachment">
                        <field name="attachment" filename="attachment_filename" readonly="state == 'done'"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_overtime_payment_search" model="ir.ui.view">
        <field name="name">hr.overtime.payment.search</field>
        <field name="model">hr.overtime.payment</field>
        <field name="arch" type="xml">
            <search string="Search Overtime">
                <field name="employee_id"/>
                <field name="date"/>

                <filter name="approved"
                        string="Approved"
                        domain="[('state','=','done')]"/>

                <filter name="pending"
                        string="Pending"
                        domain="[('state','=','draft')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_employee"
                            string="Employee"
                            context="{'group_by':'employee_id'}"/>

                    <filter name="group_date"
                            string="Date"
                            context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_overtime_payments" model="ir.actions.act_window">
        <field name="name">Overtime Payments</field>
        <field name="res_model">hr.overtime.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_hr_overtime_payment_tree"/>
        <field name="search_view_id" ref="view_hr_overtime_payment_search"/>
    </record>

</odoo>
