<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_servilopd" model="ir.ui.view">
        <field name="name">res.partner.form.servilopd</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet//group" position="inside">
                <group string="ServiLOPD">
                    <field name="lopd_state" readonly="1"/>
                </group>
            </xpath>

            <xpath expr="//field[@name='lopd_state']" position="after">
                <button name="action_send_lopd_request"
                        type="object"
                        string="Enviar formulario LOPD"
                        class="btn-primary"/>
            </xpath>

        </field>
    </record>

</odoo>