<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_servilopd_document_tree" model="ir.ui.view">
        <field name="name">servilopd.document.tree</field>
        <field name="model">servilopd.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="display_name"/>
                <field name="version"/>
                <field name="filename"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_servilopd_document_form" model="ir.ui.view">
        <field name="name">servilopd.document.form</field>
        <field name="model">servilopd.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="version"/>
                        <field name="active"/>
                    </group>

                    <group>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_servilopd_document" model="ir.actions.act_window">
        <field name="name">Documentos LOPD</field>
        <field name="res_model">servilopd.document</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>