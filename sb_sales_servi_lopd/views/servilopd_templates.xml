<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Formulario -->
    <template id="lopd_form_template">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h2>Formulario LOPD</h2>

                <p>Cliente: <t t-esc="request_record.partner_id.name"/></p>

                <form action="/lopd/form/submit" method="post">

                    <input type="hidden" name="token" t-att-value="request_record.token"/>
                
                    <div>
                        <label>Nombre Empresa</label>
                        <input type="text" name="company_name" t-att-value="request_record.partner_id.company_name or ''"/>
                    </div>
                    
                    <div>
                        <label>Nombre Completo</label>
                        <input type="text" name="fullname" t-att-value="request_record.partner_id.name or ''"/>
                    </div>

                    <div>
                        <label>Email</label>
                        <input type="email" name="email" t-att-value="request_record.partner_id.email or ''"/>
                    </div>

                    <div>
                        <label>CIF/NIF</label>
                        <input type="text" name="vat" t-att-value="request_record.partner_id.vat or ''"/>
                    </div>

                    <div>
                        <label>Teléfono</label>
                        <input type="tel" name="phone" t-att-value="request_record.partner_id.phone or ''"/>
                        
                        <label>Móvil</label>
                        <input type="tel" name="mobile" t-att-value="request_record.partner_id.mobile or ''"/>
                    </div>

                    <div>
                        <label>
                            <input type="checkbox" required="required"/>
                            Acepto la LOPD
                        </label>
                    </div>

                    <button type="submit">Enviar</button>
                </form>
            </div>
        </t>
    </template>

    <!-- Token inválido -->
    <template id="token_invalid">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h3>Enlace inválido</h3>
            </div>
        </t>
    </template>

    <!-- Token expirado -->
    <template id="token_expired">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h3>El enlace ha expirado</h3>
            </div>
        </t>
    </template>

    <!-- Envio correcto -->
    <template id="lopd_thanks" name="Gracias LOPD">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h2>Gracias</h2>
                <p>Hemos recibido tus datos correctamente.</p>
            </div>
        </t>
    </template>

    <!-- Evita el doble envio de Form -->
    <template id="lopd_already_submitted" name="LOPD ya enviada">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h2>Formulario ya enviado</h2>
                <p>Este formulario ya fue completado anteriormente.</p>
            </div>
        </t>
    </template>

</odoo>