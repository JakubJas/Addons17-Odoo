<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_lopd_request" model="mail.template">
        <field name="name">ServiLOPD - Solicitud de datos</field>
        <field name="model_id" ref="model_servilopd_request"/>
        <field name="subject">Solicitud de información LOPD</field>
        <field name="email_from">{{ user.email_formatted }}</field>
        <field name="email_to">{{ object.email_to }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; color: #333; max-width: 650px; margin: 0 auto;">

                <div style="background-color: #1f3a4a; color: white; padding: 24px; border-radius: 8px 8px 0 0;">
                    <h2 style="margin: 0;">Actualización de datos LOPD</h2>
                    <p style="margin: 8px 0 0 0;">
                        Solicitud de confirmación de datos
                    </p>
                </div>

                <div style="border: 1px solid #ddd; border-top: 0; padding: 24px; border-radius: 0 0 8px 8px;">

                    <p>Hola <strong><t t-out="object.partner_id.name"/></strong>,</p>

                    <p>
                        Necesitamos que revises y confirmes tus datos para mantener actualizada
                        nuestra información y gestionar correctamente la aceptación LOPD.
                    </p>

                    <p>
                        El formulario está precargado con los datos que tenemos actualmente.
                        Puedes corregir cualquier información antes de enviarlo.
                    </p>

                    <p style="text-align: center; margin: 32px 0;">
                        <a t-att-href="object.form_url"
                        style="background-color:#1f3a4a;color:white;padding:14px 24px;text-decoration:none;border-radius:6px;font-weight:bold;display:inline-block;">
                            Completar formulario LOPD
                        </a>
                    </p>

                    <p style="font-size: 14px; color: #666;">
                        Este enlace es personal, único y caduca el:
                        <strong><t t-out="object.token_expiration"/></strong>
                    </p>

                    <p style="font-size: 14px; color: #666;">
                        Si no esperabas este mensaje o tienes dudas, puedes contactar con nosotros antes de completar el formulario.
                        A travez de este correo ventas@servibyte.com .
                    </p>

                    <hr style="border: none; border-top: 1px solid #eee; margin: 24px 0;"/>

                    <p style="font-size: 12px; color: #999;">
                        Este correo ha sido generado automáticamente por ServiLOPD.
                    </p>

                </div>
            </div>
        </field>
    </record>

    <record id="mail_template_lopd_contract_final" model="mail.template">
        <field name="name">ServiLOPD - Contrato final</field>
        <field name="model_id" ref="model_servilopd_request"/>
        <field name="subject">Contrato LOPD confirmado</field>
        <field name="email_from">{{ user.email_formatted }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; color: #333;">
                <p>Hola <strong><t t-out="object.fullname or object.partner_id.name"/></strong>,</p>

                <p>
                    Hemos recibido correctamente tus datos y la aceptación del contrato LOPD.
                </p>

                <p>
                    Adjuntamos el contrato generado con la información facilitada.
                </p>

                <p>Gracias.</p>
            </div>
        </field>
    </record>

</odoo>