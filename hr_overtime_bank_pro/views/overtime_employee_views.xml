<odoo>

    <record id="view_employee_overtime" model="ir.ui.view">
        <field name="name">hr.employee.overtime</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="inside">

                <page string="Overtime Bank" groups="hr_overtime_bank_pro.group_overtime_hr, hr_overtime_bank_pro.group_overtime_admin">

                    <!-- Hay que ajustar el botón para que genere el pop up y no que te envie al over time. Tambien tiene que pasar
                    al usuario que se va a crear le el registro -->
                    <group>
                        <button name="%(action_overtime_entries)d"
                            type="action"
                            string="Nuevo"
                            class="btn-primary"/>
                    </group>
                    
                    <group>                        
                        <field name="overtime_balance" widget="float_time"/>
                    </group>

                    <field name="overtime_entry_ids" groups="hr_overtime_bank_pro.group_overtime_hr, hr_overtime_bank_pro.group_overtime_admin">
                        <tree>
                            <field name="date" string="Fecha"/>
                            <field name="type" string="Tipo"/>
                            <field name="hours" string="Horas"/>
                            <field name="reference" string="Referencia"/>
                            <field name="state" string="Estado"/>
                        </tree>
                    </field>

                </page>

            </xpath>

        </field>
    </record>

</odoo>