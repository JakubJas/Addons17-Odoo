<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sb_hr_serviflow_option_tree" model="ir.ui.view">
        <field name="name">sb.hr.serviflow.option.tree</field>
        <field name="model">sb.hr.serviflow.option</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_sb_hr_serviflow_option_form" model="ir.ui.view">
        <field name="name">sb.hr.serviflow.option.form</field>
        <field name="model">sb.hr.serviflow.option</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sb_hr_serviflow_option" model="ir.actions.act_window">
        <field name="name">Opciones Serviflow</field>
        <field name="res_model">sb.hr.serviflow.option</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_sb_hr_serviflow_root"
              name="Serviflow"
              parent="hr.menu_hr_root"
              sequence="90"/>

    <menuitem id="menu_sb_hr_serviflow_option"
              name="Opciones"
              parent="menu_sb_hr_serviflow_root"
              action="action_sb_hr_serviflow_option"
              sequence="10"/>

</odoo>
