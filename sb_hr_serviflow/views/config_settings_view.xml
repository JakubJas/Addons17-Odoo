<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_sb_hr_serviflow" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sb.hr.serviflow</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Serviflow" name="sb_hr_serviflow" data-key="sb_hr_serviflow">
                    <block title="Configuración global Serviflow">
                        <setting string="Flujo activo"
                                 help="Selecciona el flujo activo global para todas las empresas.">
                            <field name="serviflow_active_option_id" options="{'no_create': False}"/>
                            <div class="mt16">
                                <button name="%(sb_hr_serviflow.action_sb_hr_serviflow_option)d"
                                        type="action"
                                        string="Administrar flujos"
                                        class="btn btn-secondary"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
