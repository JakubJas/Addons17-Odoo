<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_serviflow_task_tree" model="ir.ui.view">
        <field name="name">serviflow.task.tree</field>
        <field name="model">serviflow.task</field>
        <field name="arch" type="xml">
            <tree string="Solicitudes Serviflow">
                <field name="name"/>
                <field name="opportunity_id"/>
                <field name="state"/>
                <field name="review_result"/>
                <field name="assigned_user_id"/>
                <field name="accepted_user_id"/>
                <field name="task_type"/>
                <field name="create_date"/>
                <button name="action_accept"
                        string="Aceptar"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'pending'"/>
                <button name="action_done"
                        string="Hecho"
                        type="object"
                        class="btn-success"
                        invisible="state != 'accepted' or accepted_user_id != uid or task_type != 'budget'"/>
            </tree>
        </field>
    </record>

    <record id="view_serviflow_task_form" model="ir.ui.view">
        <field name="name">serviflow.task.form</field>
        <field name="model">serviflow.task</field>
        <field name="arch" type="xml">
            <form string="Solicitud Serviflow">
                <header>
                    <button name="action_accept"
                            string="Aceptar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_done"
                            string="Marcar como hecho"
                            type="object"
                            class="btn-success"
                            invisible="state != 'accepted' or accepted_user_id != uid or task_type != 'budget'"/>
                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reassign"
                            string="Reasignar"
                            type="object"
                            class="btn-secondary"
                            groups="sb_hr_serviflow.group_serviflow_manager"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_review_approve"
                            string="Aprobar"
                            type="object"
                            class="btn-success"
                            invisible="task_type != 'review' or review_result != 'pending' or assigned_user_id != uid"/>
                    <button name="action_review_reject"
                            string="Rechazar"
                            type="object"
                            class="btn-danger"
                            invisible="task_type != 'review' or review_result != 'pending' or assigned_user_id != uid"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="task_type"/>
                        <field name="review_result"/>

                        <field name="name"/>
                        <field name="opportunity_id"/>
                        <field name="assigned_user_id"/>
                        <field name="accepted_user_id"/>
                        <field name="reassign_user_id" groups="sb_hr_serviflow.group_serviflow_manager"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_serviflow_task_user" model="ir.actions.act_window">
        <field name="name">Mis Solicitudes</field>
        <field name="res_model">serviflow.task</field>
        <field name="view_mode">tree,form</field>

        <field name="domain">
        [
            '|',
            ('state', '=', 'pending'),
            ('assigned_user_id', '=', uid)
        ]
        </field>
    </record>


    <record id="action_serviflow_task_manager" model="ir.actions.act_window">
        <field name="name">Todas las Solicitudes</field>
        <field name="res_model">serviflow.task</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_serviflow_root"
              name="Serviflow"
              sequence="20"/>

    <menuitem id="menu_serviflow_tasks_user"
              name="Mis Solicitudes"
              parent="menu_serviflow_root"
              action="action_serviflow_task_user"
              sequence="10"
              groups="sb_hr_serviflow.group_serviflow_office_tech"/>


    <menuitem id="menu_serviflow_tasks_manager"
              name="Todas las Solicitudes"
              parent="menu_serviflow_root"
              action="action_serviflow_task_manager"
              sequence="20"
              groups="sb_hr_serviflow.group_serviflow_manager"/>

    <menuitem id="menu_serviflow_reviewer_config"
          name="Revisores"
          parent="menu_serviflow_root"
          action="action_serviflow_reviewer_config"
          sequence="50"/>

</odoo>